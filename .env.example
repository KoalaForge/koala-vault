# Application
NODE_ENV=development
PORT=3000
WEBHOOK_BASE_URL=https://your-domain.com
WEBHOOK_PATH_SECRET=your-random-secret-path-min-16-chars

# MongoDB
DATABASE_URL=mongodb://koalavault:password@localhost:27017/koalavault?authSource=admin

# Security
IMAP_ENCRYPTION_KEY=your-64-char-hex-key-here-change-this-in-production
TELEGRAM_WEBHOOK_SECRET=your-random-webhook-secret-token-min-16-chars

# Master Bot
MASTER_BOT_TOKEN=your-master-bot-token-here
MASTER_OWNER_TELEGRAM_ID=your-telegram-user-id

# Logging
LOG_LEVEL=info
